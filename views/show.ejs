<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Invoice Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/style.css">

</head>

<body>

<div class="container mt-5">

    <div class="card shadow p-4">

        <h1 class="mb-4">
            Invoice Details
        </h1>

        <h3>
            Customer:
            <%= invoice.customerName %>
        </h3>

        <hr>

        <h4 class="mt-4">
            Items
        </h4>

        <ul class="list-group mb-4">

            <% invoice.items.forEach(item => { %>

                <li class="list-group-item">

                    <strong>
                        <%= item.name %>
                    </strong>

                    <br>

                    Quantity:
                    <%= item.quantity %>

                    <br>

                    Price:
                    ₹ <%= item.price %>

                </li>

            <% }) %>

        </ul>

        <h5>
            Subtotal:
            ₹ <%= invoice.subtotal %>
        </h5>

        <h5>
            GST:
            ₹ <%= invoice.gst %>
        </h5>

        <h4 class="mt-3">
            Total:
            ₹ <%= invoice.total %>
        </h4>

        <p class="mt-3">

            Status:

            <strong>
                <%= invoice.status %>
            </strong>

        </p>

        <a href="/invoices/<%= invoice._id %>/edit" class="btn btn-primary mt-3">
            Edit
        </a>
    <form action="/invoices/<%= invoice._id %>?_method=DELETE" method="POST">
        <button type="submit" class="btn btn-danger mt-3">Delete</button>
    </form>


    <a href="/invoices/<%= invoice._id %>/pdf" class="btn btn-secondary mt-3">
            Download PDF
        </a>


        <a href="/invoices" class="btn btn-dark mt-3">
            Back
        </a>

    </div>

</div>

</body>

</html>