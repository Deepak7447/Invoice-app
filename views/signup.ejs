<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
</head>

<body>

<div class="container mt-5">

    <h1 class="mb-4">Signup</h1>

    <form action="/signup" method="POST">

        <div>
            <label class="form-label">
                Username
            </label>

            <input 
                type="text"
                name="username"
                class="form-control"
                required
            >
        </div>

        <div>
            <label class="form-label">
                Email
            </label>

            <input 
                type="email"
                name="email"
                class="form-control"
                required
            >
        </div>

        <div>

            <label class="form-label">
                Password
            </label>

            <input
                type="password"
                name="password"
                class="form-control"
                required
            >

        </div>

        <button 
            type="submit"
            class="btn btn-primary mt-3"
        >
            Signup
        </button>

    </form>

</div>

</body>
</html>